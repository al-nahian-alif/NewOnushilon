<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.SettingsController"
      prefWidth="1200" prefHeight="820"
      maxWidth="Infinity" maxHeight="Infinity"
      style="-fx-background-color:#f5f7f8;">

    <fx:include source="Sidebar.fxml" fx:id="sidebar"/>

    <ScrollPane fx:id="mainScroll" HBox.hgrow="ALWAYS"
                fitToWidth="true" fitToHeight="false"
                style="-fx-background-color:#f5f7f8; -fx-background:#f5f7f8;
                       -fx-border-color:transparent; -fx-padding:0;">

        <VBox style="-fx-background-color:#f5f7f8; -fx-padding:32 56 48 56;"
              spacing="0" fillWidth="true">

            <VBox spacing="4" style="-fx-padding:0 0 28 0;">
                <Label text="Settings"
                       style="-fx-font-size:28px; -fx-font-weight:900; -fx-text-fill:#0f172a;"/>
                <Label text="Manage your account preferences and study goals"
                       style="-fx-font-size:13px; -fx-text-fill:#64748b;"/>
            </VBox>

            <VBox spacing="20">

                <VBox style="-fx-background-color:#ffffff; -fx-background-radius:16;
                             -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:16;
                             -fx-padding:24;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.04),8,0,0,2);"
                      spacing="16">

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="👤" style="-fx-font-size:15px; -fx-text-fill:#0d7ff2;"/>
                        <Label text="Profile Section"
                               style="-fx-font-size:16px; -fx-font-weight:bold;
                                      -fx-text-fill:#0f172a;"/>
                    </HBox>

                    <HBox spacing="18" alignment="CENTER_LEFT">

                        <StackPane fx:id="avatarCircle"
                                   style="-fx-background-color:#dbeafe; -fx-background-radius:50;
                                          -fx-min-width:76; -fx-min-height:76;
                                          -fx-pref-width:76; -fx-pref-height:76;
                                          -fx-border-color:#ffffff; -fx-border-width:3;
                                          -fx-border-radius:50;
                                          -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.10),8,0,0,2);"
                                   alignment="CENTER">
                            <Label fx:id="avatarInitials" text="?"
                                   style="-fx-font-size:24px; -fx-font-weight:900;
                                          -fx-text-fill:#0d7ff2;"/>
                        </StackPane>

                        <VBox fx:id="profileViewMode" HBox.hgrow="ALWAYS" spacing="5">
                            <Label fx:id="profileNameLabel" text="Loading..."
                                   style="-fx-font-size:18px; -fx-font-weight:bold;
                                          -fx-text-fill:#0f172a;"/>
                            <Label fx:id="profileEmailLabel" text=""
                                   style="-fx-font-size:13px; -fx-text-fill:#64748b;"/>
                            <Label fx:id="studentIdLabel" text=""
                                   style="-fx-background-color:#dbeafe; -fx-background-radius:5;
                                          -fx-text-fill:#1d4ed8; -fx-font-size:11px;
                                          -fx-font-weight:bold; -fx-padding:3 10;"/>
                        </VBox>

                        <HBox fx:id="profileEditMode" visible="false" managed="false"
                              HBox.hgrow="ALWAYS" spacing="10" alignment="CENTER_LEFT">
                            <TextField fx:id="editNameField" promptText="Your full name"
                                       prefWidth="260"
                                       style="-fx-background-color:#f8fafc;
                                              -fx-background-radius:8;
                                              -fx-border-color:#0d7ff2; -fx-border-width:1.5;
                                              -fx-border-radius:8; -fx-font-size:14px;
                                              -fx-padding:10 14;"/>
                            <Button text="Save" onAction="#onSaveName"
                                    style="-fx-background-color:#0d7ff2; -fx-background-radius:8;
                                           -fx-text-fill:white; -fx-font-size:13px;
                                           -fx-font-weight:bold; -fx-padding:10 22;
                                           -fx-cursor:hand;"/>
                            <Button text="Cancel" onAction="#onCancelEdit"
                                    style="-fx-background-color:#f1f5f9; -fx-background-radius:8;
                                           -fx-text-fill:#334155; -fx-font-size:13px;
                                           -fx-padding:10 16; -fx-cursor:hand;"/>
                        </HBox>

                        <Button fx:id="editProfileBtn" text="Edit Profile"
                                onAction="#onEditProfile"
                                style="-fx-background-color:#f1f5f9; -fx-background-radius:10;
                                       -fx-border-color:#e2e8f0; -fx-border-width:1;
                                       -fx-border-radius:10; -fx-text-fill:#334155;
                                       -fx-font-size:13px; -fx-font-weight:600;
                                       -fx-padding:10 22; -fx-cursor:hand;"/>
                    </HBox>

                    <Label fx:id="profileSavedLabel" text=""
                           style="-fx-font-size:12px; -fx-text-fill:#22c55e;"/>
                </VBox>

                <VBox style="-fx-background-color:#fff5f5; -fx-background-radius:16;
                             -fx-border-color:#fecaca; -fx-border-width:1; -fx-border-radius:16;
                             -fx-padding:24;"
                      spacing="10">

                    <Label text="Danger Zone"
                           style="-fx-font-size:16px; -fx-font-weight:bold;
                                  -fx-text-fill:#dc2626;"/>
                    <Label text="Irreversible actions that affect your account data."
                           style="-fx-font-size:12px; -fx-text-fill:#f87171;"/>

                    <HBox alignment="CENTER_LEFT" style="-fx-padding:6 0 0 0;">
                        <VBox HBox.hgrow="ALWAYS" spacing="4">
                            <Label text="Delete Account"
                                   style="-fx-font-size:14px; -fx-font-weight:bold;
                                          -fx-text-fill:#0f172a;"/>
                            <Label text="Permanently delete your profile and all study history."
                                   style="-fx-font-size:12px; -fx-text-fill:#64748b;"/>
                        </VBox>
                        <Button text="Delete Account"
                                onAction="#onDeleteAccount"
                                style="-fx-background-color:#dc2626; -fx-background-radius:10;
                                       -fx-text-fill:white; -fx-font-size:13px;
                                       -fx-font-weight:bold; -fx-padding:11 22;
                                       -fx-cursor:hand;
                                       -fx-effect:dropshadow(gaussian,rgba(220,38,38,0.30),10,0,0,3);"/>
                    </HBox>
                </VBox>

                <Label text="HSC PREP APP v2.4.0  •  BUILT FOR SUCCESS"
                       style="-fx-font-size:10px; -fx-text-fill:#cbd5e1; -fx-font-weight:bold;"
                       maxWidth="Infinity" textAlignment="CENTER"/>

            </VBox>
        </VBox>
    </ScrollPane>
</HBox>