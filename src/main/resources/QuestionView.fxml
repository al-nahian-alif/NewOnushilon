<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.QuestionController"
      prefWidth="1200" prefHeight="820"
      maxWidth="Infinity" maxHeight="Infinity"
      style="-fx-background-color:#f5f7f8;">

    <!-- ── SIDEBAR ── -->
    <fx:include source="Sidebar.fxml" fx:id="sidebar"/>

    <!-- ── MAIN SCROLL ── -->
    <ScrollPane fx:id="mainScroll" HBox.hgrow="ALWAYS"
                fitToWidth="true" fitToHeight="false"
                style="-fx-background-color:#f5f7f8; -fx-background:#f5f7f8;
                       -fx-border-color:transparent; -fx-padding:0;">

        <VBox style="-fx-background-color:#f5f7f8; -fx-padding:22 64 48 64;"
              spacing="16" fillWidth="true">

            <!-- ══ STATUS BAR ══ -->
            <HBox style="-fx-background-color:#ffffff; -fx-background-radius:14;
                         -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:14;
                         -fx-padding:12 20;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.04),6,0,0,1);"
                  alignment="CENTER_LEFT" spacing="0">

                <!-- Exit button -->
                <Button fx:id="exitBtn" text="✕  Exit" onAction="#onExit"
                        style="-fx-background-color:transparent; -fx-border-color:#e2e8f0;
                               -fx-border-width:1; -fx-border-radius:8; -fx-background-radius:8;
                               -fx-text-fill:#64748b; -fx-font-size:12px; -fx-padding:6 12;
                               -fx-cursor:hand;"/>

                <Region prefWidth="16"/>

                <!-- Progress info + bar -->
                <VBox HBox.hgrow="ALWAYS" spacing="6">
                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="questionCountLabel" text="Question 1 of 1"
                               style="-fx-font-size:12px; -fx-font-weight:500;
                                      -fx-text-fill:#64748b;" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="statusRightLabel" text=""
                               style="-fx-font-size:12px; -fx-text-fill:#64748b;"/>
                    </HBox>
                    <StackPane prefHeight="8" minHeight="8" maxHeight="8">
                        <HBox style="-fx-background-color:#f1f5f9; -fx-background-radius:100;"
                              maxWidth="Infinity" prefHeight="8"/>
                        <HBox fx:id="progressBar"
                              style="-fx-background-color:#0d7ff2; -fx-background-radius:100;"
                              prefHeight="8" StackPane.alignment="CENTER_LEFT"/>
                    </StackPane>
                </VBox>

                <!-- Right: stopwatch + mock countdown + status badge -->
                <VBox style="-fx-border-color:transparent transparent transparent #e2e8f0;
                             -fx-border-width:0 0 0 1; -fx-padding:0 0 0 20;" spacing="0">
                    <HBox alignment="CENTER_LEFT" spacing="16">

                        <!-- Elapsed time (always visible) -->
                        <VBox alignment="CENTER" spacing="1">
                            <Label text="TIME TAKEN"
                                   style="-fx-font-size:9px; -fx-font-weight:bold;
                                          -fx-text-fill:#94a3b8;"/>
                            <Label fx:id="timerLabel" text="00:00:00"
                                   style="-fx-font-size:17px; -fx-font-weight:bold;
                                          -fx-text-fill:#0f172a;"/>
                        </VBox>

                        <!-- MOCK EXAM countdown (hidden by default) -->
                        <VBox fx:id="countdownBox" visible="false" managed="false"
                              alignment="CENTER" spacing="1">
                            <Label text="REMAINING"
                                   style="-fx-font-size:9px; -fx-font-weight:bold;
                                          -fx-text-fill:#94a3b8;"/>
                            <Label fx:id="countdownLabel" text="00:00"
                                   style="-fx-font-size:17px; -fx-font-weight:bold;
                                          -fx-text-fill:#ef4444;"/>
                        </VBox>

                        <!-- Status badge -->
                        <HBox fx:id="statusBadge" spacing="5" alignment="CENTER"
                              style="-fx-background-color:#dbeafe; -fx-background-radius:50;
                                     -fx-padding:5 14;">
                            <Label fx:id="statusIcon" text="⏱"
                                   style="-fx-font-size:12px;"/>
                            <Label fx:id="statusLabel" text="In Progress"
                                   style="-fx-font-size:12px; -fx-font-weight:bold;
                                          -fx-text-fill:#2563eb;"/>
                        </HBox>
                    </HBox>
                </VBox>
            </HBox>

            <!-- ══ QUESTION CARD ══ -->
            <VBox style="-fx-background-color:#ffffff; -fx-background-radius:16;
                         -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:16;
                         -fx-padding:32; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),8,0,0,2);"
                  spacing="0">

                <!-- Breadcrumb badge: Subject • Chapter • Difficulty -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label fx:id="subjectBadge" text="Subject • Chapter"
                           style="-fx-background-color:#f1f5f9; -fx-background-radius:50;
                                  -fx-text-fill:#475569; -fx-font-size:11px;
                                  -fx-font-weight:bold; -fx-padding:4 12;"/>
                    <!-- Mode badge (MOCK EXAM / QUICK QUIZ etc) -->
                    <Label fx:id="modeBadge" text="" visible="false" managed="false"
                           style="-fx-background-color:#f5f3ff; -fx-background-radius:50;
                                  -fx-text-fill:#7c3aed; -fx-font-size:11px;
                                  -fx-font-weight:bold; -fx-padding:4 12;"/>
                </HBox>

                <Region prefHeight="18"/>

                <!-- Question body -->
                <Label fx:id="questionLabel" text="Loading question..."
                       style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#0f172a;
                              -fx-wrap-text:true;"
                       wrapText="true" maxWidth="Infinity"/>

                <Region prefHeight="24"/>

                <!-- Answer options (dynamically built) -->
                <VBox fx:id="optionsBox" spacing="10"/>

            </VBox>

            <!-- ══ HINT CARD (pre-submit) ══ -->
            <HBox fx:id="hintCard"
                  style="-fx-background-color:#eff6ff; -fx-background-radius:14;
                         -fx-border-color:#bfdbfe; -fx-border-width:1; -fx-border-radius:14;
                         -fx-padding:20;" spacing="20" alignment="CENTER_LEFT">
                <VBox HBox.hgrow="ALWAYS" spacing="6">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="💡" style="-fx-font-size:15px;"/>
                        <Label text="Stuck on this question?"
                               style="-fx-font-size:14px; -fx-font-weight:bold;
                                      -fx-text-fill:#0d7ff2;"/>
                    </HBox>
                    <Label fx:id="hintLabel"
                           text="Review the relevant chapter in your study materials."
                           style="-fx-font-size:13px; -fx-text-fill:#334155;"
                           wrapText="true" maxWidth="Infinity"/>
                </VBox>
                <Button text="View Study Material" onAction="#onViewStudyMaterial"
                        style="-fx-background-color:#ffffff; -fx-background-radius:10;
                               -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:10;
                               -fx-text-fill:#0d7ff2; -fx-font-size:13px; -fx-font-weight:bold;
                               -fx-padding:10 18; -fx-cursor:hand;"/>
            </HBox>

            <!-- ══ AI EXPLANATION CARD (post-submit) ══ -->
            <VBox fx:id="aiExplanationCard" visible="false" managed="false"
                  style="-fx-background-color:#eff6ff; -fx-background-radius:14;
                         -fx-border-color:#bfdbfe; -fx-border-width:1; -fx-border-radius:14;
                         -fx-padding:26;" spacing="12">

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="✦" style="-fx-font-size:16px; -fx-text-fill:#0d7ff2;"/>
                    <Label text="AI Explanation"
                           style="-fx-font-size:16px; -fx-font-weight:bold;
                                  -fx-text-fill:#0d7ff2;"/>
                </HBox>

                <Label fx:id="aiExplanationText" text=""
                       style="-fx-font-size:13px; -fx-text-fill:#334155; -fx-line-spacing:3;"
                       wrapText="true" maxWidth="Infinity"/>

                <!-- Key points -->
                <VBox fx:id="keyPointsBox" spacing="8"
                      style="-fx-background-color:#ffffff; -fx-background-radius:10;
                             -fx-border-color:#bfdbfe; -fx-border-width:1; -fx-border-radius:10;
                             -fx-padding:14;">
                    <Label text="Key Points"
                           style="-fx-font-size:12px; -fx-font-weight:bold;
                                  -fx-text-fill:#0d7ff2;"/>
                </VBox>

                <!-- Correct answer highlight -->
                <HBox spacing="10" alignment="CENTER_LEFT"
                      style="-fx-background-color:#f0fdf4; -fx-background-radius:10;
                             -fx-border-color:#bbf7d0; -fx-border-width:1; -fx-border-radius:10;
                             -fx-padding:12 16;">
                    <Label text="✓"
                           style="-fx-font-size:16px; -fx-text-fill:#16a34a;
                                  -fx-font-weight:bold;"/>
                    <Label text="Correct Answer:"
                           style="-fx-font-size:12px; -fx-font-weight:bold;
                                  -fx-text-fill:#15803d;"/>
                    <Label fx:id="correctAnswerHighlight" text=""
                           style="-fx-font-size:13px; -fx-font-weight:bold;
                                  -fx-text-fill:#0f172a;"
                           wrapText="true" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <!-- ══ MY NOTES CARD (post-submit) ══ -->
            <VBox fx:id="notesCard" visible="false" managed="false"
                  style="-fx-background-color:#ffffff; -fx-background-radius:14;
                         -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:14;
                         -fx-padding:22;" spacing="10">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="📝" style="-fx-font-size:15px;"/>
                    <Label text="My Notes"
                           style="-fx-font-size:15px; -fx-font-weight:bold;
                                  -fx-text-fill:#0f172a;"/>
                </HBox>
                <TextArea fx:id="notesArea"
                          promptText="Add your study notes here for later review..."
                          prefRowCount="3"
                          style="-fx-background-color:#f8fafc; -fx-background-radius:10;
                                 -fx-border-color:#e2e8f0; -fx-border-width:1;
                                 -fx-border-radius:10; -fx-font-size:13px;
                                 -fx-text-fill:#334155; -fx-padding:10;"/>
                <Label fx:id="notesSavedLabel" text=""
                       style="-fx-font-size:11px; -fx-text-fill:#22c55e;"/>
            </VBox>

            <!-- ══ ACTION FOOTER ══ -->
            <HBox alignment="CENTER_LEFT" spacing="14">

                <!-- Left: Save for later / Report issue -->
                <Button fx:id="leftActionBtn" text="🔖  Save for later"
                        onAction="#onLeftAction"
                        style="-fx-background-color:transparent; -fx-border-color:transparent;
                               -fx-text-fill:#64748b; -fx-font-size:13px; -fx-font-weight:500;
                               -fx-cursor:hand;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Live score tally -->
                <HBox spacing="14" alignment="CENTER">
                    <HBox spacing="5" alignment="CENTER">
                        <Label text="✓"
                               style="-fx-font-size:13px; -fx-text-fill:#22c55e;
                                      -fx-font-weight:bold;"/>
                        <Label fx:id="correctCountLabel" text="0"
                               style="-fx-font-size:13px; -fx-font-weight:bold;
                                      -fx-text-fill:#22c55e;"/>
                    </HBox>
                    <HBox spacing="5" alignment="CENTER">
                        <Label text="✗"
                               style="-fx-font-size:13px; -fx-text-fill:#ef4444;
                                      -fx-font-weight:bold;"/>
                        <Label fx:id="wrongCountLabel" text="0"
                               style="-fx-font-size:13px; -fx-font-weight:bold;
                                      -fx-text-fill:#ef4444;"/>
                    </HBox>
                    <HBox spacing="5" alignment="CENTER">
                        <Label text="⟳"
                               style="-fx-font-size:13px; -fx-text-fill:#94a3b8;
                                      -fx-font-weight:bold;"/>
                        <Label fx:id="skippedCountLabel" text="0"
                               style="-fx-font-size:13px; -fx-font-weight:bold;
                                      -fx-text-fill:#94a3b8;"/>
                    </HBox>
                </HBox>

                <Region prefWidth="8"/>

                <!-- Previous -->
                <Button fx:id="prevBtn" text="Previous" onAction="#onPrevious"
                        style="-fx-background-color:#ffffff; -fx-background-radius:10;
                               -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:10;
                               -fx-text-fill:#334155; -fx-font-size:13px; -fx-font-weight:600;
                               -fx-padding:11 24; -fx-cursor:hand;" disable="true"/>

                <!-- Submit / Next -->
                <Button fx:id="submitBtn" text="Submit Answer  ▶"
                        onAction="#onSubmitOrNext"
                        style="-fx-background-color:#0d7ff2; -fx-background-radius:10;
                               -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold;
                               -fx-padding:11 28; -fx-cursor:hand;
                               -fx-effect:dropshadow(gaussian,rgba(13,127,242,0.30),12,0,0,4);"/>

                <!-- Skip -->
                <Button fx:id="skipBtn" text="Skip →" onAction="#onSkip"
                        style="-fx-background-color:transparent; -fx-border-color:transparent;
                               -fx-text-fill:#94a3b8; -fx-font-size:13px;
                               -fx-padding:11 0; -fx-cursor:hand;"/>

                <!-- Add to Mistake Bank -->
                <Button fx:id="addMistakeBtn" text="➕  Mistake Bank"
                        visible="false" managed="false"
                        onAction="#onAddToMistakeBank"
                        style="-fx-background-color:#fee2e2; -fx-background-radius:10;
                               -fx-text-fill:#dc2626; -fx-font-size:12px; -fx-font-weight:bold;
                               -fx-padding:11 16; -fx-cursor:hand;"/>
            </HBox>

        </VBox>
    </ScrollPane>
</HBox>
