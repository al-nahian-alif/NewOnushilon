                     <children>
                        <Label fx:id="questionLabel" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="600.0" styleClass="question-box" text="Appleton's population is 400 greater than Berryville's population. If Berryville's population were reduced by 900 people, then Appleton's population would be 3 times as large as Berryville's population. What is Berryville's current population?" wrapText="true" HBox.hgrow="ALWAYS" />
