<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.PerformanceController"
      prefWidth="1280" prefHeight="820"
      maxWidth="Infinity" maxHeight="Infinity"
      style="-fx-background-color:#f5f7f8;">

    <!-- ── SIDEBAR ── -->
    <fx:include source="Sidebar.fxml" fx:id="sidebar"/>

    <!-- ── MAIN SCROLL ── -->
    <ScrollPane fx:id="mainScroll" HBox.hgrow="ALWAYS"
                fitToWidth="true" fitToHeight="false"
                style="-fx-background-color:#f5f7f8; -fx-background:#f5f7f8;
                       -fx-border-color:transparent; -fx-padding:0;">

        <VBox fillWidth="true"
              style="-fx-background-color:#f5f7f8; -fx-padding:32 32 40 32;" spacing="0">

            <!-- ══ HEADER ══ -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox HBox.hgrow="ALWAYS" spacing="4">
                    <Label text="Performance &amp; Insights"
                           style="-fx-font-size:28px; -fx-font-weight:900; -fx-text-fill:#0f172a;"/>
                    <Label text="Track your trajectory across core HSC subjects."
                           style="-fx-font-size:13px; -fx-text-fill:#64748b;"/>
                </VBox>
                <!-- Period toggle -->
                <HBox spacing="2"
                      style="-fx-background-color:#ffffff; -fx-background-radius:12;
                             -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:12;
                             -fx-padding:5;">
                    <Button fx:id="btnDaily"   text="Daily"    onAction="#onDaily"
                            style="-fx-background-color:#0d7ff2; -fx-background-radius:8;
                                   -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:600;
                                   -fx-padding:7 18; -fx-cursor:hand;"/>
                    <Button fx:id="btnWeekly"  text="Weekly"   onAction="#onWeekly"
                            style="-fx-background-color:transparent; -fx-background-radius:8;
                                   -fx-text-fill:#475569; -fx-font-size:13px; -fx-font-weight:600;
                                   -fx-padding:7 18; -fx-cursor:hand;"/>
                    <Button fx:id="btnAllTime" text="All-time" onAction="#onAllTime"
                            style="-fx-background-color:transparent; -fx-background-radius:8;
                                   -fx-text-fill:#475569; -fx-font-size:13px; -fx-font-weight:600;
                                   -fx-padding:7 18; -fx-cursor:hand;"/>
                </HBox>
            </HBox>

            <Region prefHeight="28"/>

            <!-- ══ STAT CARDS ROW ══ -->
            <HBox spacing="16">

                <!-- Total XP -->
                <VBox HBox.hgrow="ALWAYS" spacing="0"
                      style="-fx-background-color:#ffffff; -fx-background-radius:16;
                             -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:16;
                             -fx-padding:22; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),8,0,0,2);">
                    <HBox alignment="CENTER_LEFT">
                        <StackPane style="-fx-background-color:#e8f3fe; -fx-background-radius:10;
                                          -fx-min-width:40; -fx-min-height:40;
                                          -fx-pref-width:40; -fx-pref-height:40;"
                                   HBox.hgrow="NEVER" alignment="CENTER">
                            <Label text="🏅" style="-fx-font-size:18px;"/>
                        </StackPane>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="xpChangeBadge" text="+0%"
                               style="-fx-background-color:#f0fdf4; -fx-background-radius:50;
                                      -fx-text-fill:#22c55e; -fx-font-size:11px;
                                      -fx-font-weight:bold; -fx-padding:3 8;"/>
                    </HBox>
                    <Region prefHeight="16"/>
                    <Label text="Total XP"
                           style="-fx-font-size:12px; -fx-font-weight:500; -fx-text-fill:#64748b;"/>
                    <Label fx:id="xpLabel" text="..."
                           style="-fx-font-size:24px; -fx-font-weight:900; -fx-text-fill:#0f172a;"/>
                </VBox>

                <!-- Global Rank -->
                <VBox HBox.hgrow="ALWAYS" spacing="0"
                      style="-fx-background-color:#ffffff; -fx-background-radius:16;
                             -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:16;
                             -fx-padding:22; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),8,0,0,2);">
                    <HBox alignment="CENTER_LEFT">
                        <StackPane style="-fx-background-color:#fff7ed; -fx-background-radius:10;
                                          -fx-min-width:40; -fx-min-height:40;
                                          -fx-pref-width:40; -fx-pref-height:40;"
                                   HBox.hgrow="NEVER" alignment="CENTER">
                            <Label text="🌐" style="-fx-font-size:18px;"/>
                        </StackPane>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="rankChangeBadge" text="—"
                               style="-fx-background-color:#f0fdf4; -fx-background-radius:50;
                                      -fx-text-fill:#22c55e; -fx-font-size:11px;
                                      -fx-font-weight:bold; -fx-padding:3 8;"/>
                    </HBox>
                    <Region prefHeight="16"/>
                    <Label text="Global Rank"
                           style="-fx-font-size:12px; -fx-font-weight:500; -fx-text-fill:#64748b;"/>
                    <Label fx:id="rankLabel" text="..."
                           style="-fx-font-size:24px; -fx-font-weight:900; -fx-text-fill:#0f172a;"/>
                </VBox>

                <!-- Avg Accuracy -->
                <VBox HBox.hgrow="ALWAYS" spacing="0"
                      style="-fx-background-color:#ffffff; -fx-background-radius:16;
                             -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:16;
                             -fx-padding:22; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),8,0,0,2);">
                    <HBox alignment="CENTER_LEFT">
                        <StackPane style="-fx-background-color:#faf5ff; -fx-background-radius:10;
                                          -fx-min-width:40; -fx-min-height:40;
                                          -fx-pref-width:40; -fx-pref-height:40;"
                                   HBox.hgrow="NEVER" alignment="CENTER">
                            <Label text="🎯" style="-fx-font-size:18px;"/>
                        </StackPane>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="accuracyChangeBadge" text="—"
                               style="-fx-background-color:#f0fdf4; -fx-background-radius:50;
                                      -fx-text-fill:#22c55e; -fx-font-size:11px;
                                      -fx-font-weight:bold; -fx-padding:3 8;"/>
                    </HBox>
                    <Region prefHeight="16"/>
                    <Label text="Avg. Accuracy"
                           style="-fx-font-size:12px; -fx-font-weight:500; -fx-text-fill:#64748b;"/>
                    <Label fx:id="accuracyLabel" text="..."
                           style="-fx-font-size:24px; -fx-font-weight:900; -fx-text-fill:#0f172a;"/>
                </VBox>

                <!-- Streak -->
                <VBox HBox.hgrow="ALWAYS" spacing="0"
                      style="-fx-background-color:#ffffff; -fx-background-radius:16;
                             -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:16;
                             -fx-padding:22; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),8,0,0,2);">
                    <HBox alignment="CENTER_LEFT">
                        <StackPane style="-fx-background-color:#f0fdf4; -fx-background-radius:10;
                                          -fx-min-width:40; -fx-min-height:40;
                                          -fx-pref-width:40; -fx-pref-height:40;"
                                   HBox.hgrow="NEVER" alignment="CENTER">
                            <Label text="⚡" style="-fx-font-size:18px;"/>
                        </StackPane>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="streakBadge" text="Active"
                               style="-fx-background-color:#f0fdf4; -fx-background-radius:50;
                                      -fx-text-fill:#22c55e; -fx-font-size:11px;
                                      -fx-font-weight:bold; -fx-padding:3 8;"/>
                    </HBox>
                    <Region prefHeight="16"/>
                    <Label text="Current Streak"
                           style="-fx-font-size:12px; -fx-font-weight:500; -fx-text-fill:#64748b;"/>
                    <Label fx:id="streakLabel" text="..."
                           style="-fx-font-size:24px; -fx-font-weight:900; -fx-text-fill:#0f172a;"/>
                </VBox>

            </HBox>

            <Region prefHeight="28"/>

            <!-- ══ BOTTOM ROW ══ -->
            <HBox spacing="20" fillHeight="true">

                <!-- ── LEFT: Leaderboard ── -->
                <VBox HBox.hgrow="ALWAYS" spacing="0"
                      style="-fx-background-color:#ffffff; -fx-background-radius:16;
                             -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:16;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.04),8,0,0,2);">

                    <HBox alignment="CENTER_LEFT" spacing="0"
                          style="-fx-padding:20 24 16 24;
                                 -fx-border-color:transparent transparent #f1f5f9 transparent;
                                 -fx-border-width:0 0 1 0;">
                        <Label text="Global Leaderboard"
                               style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#0f172a;"
                               HBox.hgrow="ALWAYS"/>
                        <Button text="View All" onAction="#onViewAll"
                                style="-fx-background-color:transparent; -fx-border-color:transparent;
                                       -fx-text-fill:#0d7ff2; -fx-font-size:13px; -fx-font-weight:bold;
                                       -fx-cursor:hand;"/>
                    </HBox>

                    <!-- Dynamic leaderboard rows -->
                    <VBox fx:id="leaderboardBox" spacing="0">
                        <Label text="Loading leaderboard..."
                               style="-fx-font-size:13px; -fx-text-fill:#94a3b8; -fx-padding:20 24;"/>
                    </VBox>

                    <!-- Realtime indicator -->
                    <HBox spacing="6" alignment="CENTER_LEFT"
                          style="-fx-padding:12 24 16 24;">
                        <Label fx:id="realtimeDot" text="●"
                               style="-fx-font-size:10px; -fx-text-fill:#94a3b8;"/>
                        <Label fx:id="realtimeLabel" text="Connecting..."
                               style="-fx-font-size:11px; -fx-text-fill:#94a3b8;"/>
                    </HBox>
                </VBox>

                <!-- ── RIGHT: Achievements + Growth Tip ── -->
                <VBox minWidth="300" prefWidth="310" maxWidth="310" spacing="18">

                    <!-- Achievements -->
                    <VBox spacing="0"
                          style="-fx-background-color:#ffffff; -fx-background-radius:16;
                                 -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:16;
                                 -fx-padding:22; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.04),8,0,0,2);">

                        <HBox alignment="CENTER_LEFT">
                            <Label text="Achievements"
                                   style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#0f172a;"
                                   HBox.hgrow="ALWAYS"/>
                            <Label fx:id="achievementCountLabel" text="0 / 0"
                                   style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#94a3b8;"/>
                        </HBox>

                        <Region prefHeight="18"/>

                        <!-- Unlocked row -->
                        <HBox fx:id="unlockedRow" spacing="0" maxWidth="Infinity">
                            <Label text="Loading achievements..."
                                   style="-fx-font-size:12px; -fx-text-fill:#94a3b8;"/>
                        </HBox>

                        <Region prefHeight="16"/>

                        <!-- Locked row -->
                        <HBox fx:id="lockedRow" spacing="0" maxWidth="Infinity"/>

                        <Region prefHeight="18"/>

                        <Button text="View All Badges" maxWidth="Infinity"
                                onAction="#onViewAllBadges"
                                style="-fx-background-color:transparent; -fx-background-radius:10;
                                       -fx-border-color:#e2e8f0; -fx-border-width:1; -fx-border-radius:10;
                                       -fx-text-fill:#334155; -fx-font-size:13px; -fx-font-weight:bold;
                                       -fx-padding:10 0; -fx-cursor:hand;"/>
                    </VBox>

                    <!-- Growth Tip -->
                    <VBox spacing="12"
                          style="-fx-background-color:#f0f7ff;
                                 -fx-background-radius:16;
                                 -fx-border-color:#bfdbfe; -fx-border-width:1; -fx-border-radius:16;
                                 -fx-padding:20;">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="💡" style="-fx-font-size:16px;"/>
                            <Label text="GROWTH TIP"
                                   style="-fx-font-size:11px; -fx-font-weight:bold;
                                          -fx-text-fill:#0d7ff2; -fx-letter-spacing:1;"/>
                        </HBox>
                        <Label fx:id="growthTipLabel"
                               text="Analysing your performance..."
                               style="-fx-font-size:12px; -fx-text-fill:#334155; -fx-line-spacing:3;"
                               wrapText="true"/>
                        <Button fx:id="startPracticeBtn" text="START PRACTICE →"
                                onAction="#onStartPractice"
                                style="-fx-background-color:transparent; -fx-border-color:transparent;
                                       -fx-text-fill:#0d7ff2; -fx-font-size:11px; -fx-font-weight:900;
                                       -fx-padding:0; -fx-cursor:hand;"/>
                    </VBox>

                </VBox>
            </HBox>

            <Region prefHeight="32"/>

            <!-- ══ ACHIEVEMENT UNLOCK TOAST (hidden by default) ══ -->
            <StackPane fx:id="toastPane" visible="false" managed="false"
                       alignment="BOTTOM_RIGHT">
                <VBox fx:id="toastBox" spacing="6"
                      style="-fx-background-color:#0f172a; -fx-background-radius:12;
                             -fx-padding:16 20; -fx-min-width:280;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.25),16,0,0,4);">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="🏆" style="-fx-font-size:20px;"/>
                        <VBox spacing="2">
                            <Label text="Achievement Unlocked!"
                                   style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:white;"/>
                            <Label fx:id="toastAchievementName" text=""
                                   style="-fx-font-size:12px; -fx-text-fill:#94a3b8;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </StackPane>

        </VBox>
    </ScrollPane>
</HBox>
